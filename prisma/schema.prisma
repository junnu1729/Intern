generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  reviews   Review[]
  saved     SavedCollege[]
}

model College {
  id          String   @id @default(cuid())
  name        String
  location    String
  fees        Int
  rating      Float
  overview    String
  placements  String

  courses     Course[]
  reviews     Review[]
  savedBy     SavedCollege[]
}

model Course {
  id         String @id @default(cuid())
  courseName String
  duration   String
  fees       Int

  collegeId  String
  college    College @relation(fields: [collegeId], references: [id])
}

model Review {
  id        String @id @default(cuid())
  rating    Int
  comment   String

  userId    String
  collegeId String

  user       User    @relation(fields: [userId], references: [id])
  college    College @relation(fields: [collegeId], references: [id])
}

model SavedCollege {
  id        String @id @default(cuid())

  userId    String
  collegeId String

  user      User    @relation(fields: [userId], references: [id])
  college   College @relation(fields: [collegeId], references: [id])

  @@unique([userId, collegeId])
}